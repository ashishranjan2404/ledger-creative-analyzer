{
  "_comment": "Paste into the butterbase apply_schema MCP tool after init_app. Creates the jobs table that tracks every creative_analyzer pipeline run end-to-end.",
  "schema": {
    "tables": {
      "jobs": {
        "columns": {
          "id":                 { "type": "uuid", "primary": true, "default": "gen_random_uuid()" },
          "creative_id":        { "type": "text", "nullable": false },
          "status":             { "type": "text", "nullable": false, "default": "'pending'" },
          "current_step":       { "type": "text" },
          "platform":           { "type": "text" },
          "media_type":         { "type": "text" },
          "source_url":         { "type": "text" },
          "merchant_name":      { "type": "text" },
          "features":           { "type": "jsonb" },
          "vote_log":           { "type": "jsonb" },
          "confidence":         { "type": "numeric" },
          "hook_copy":          { "type": "text" },
          "description":        { "type": "text" },
          "discovered_tags":    { "type": "text[]" },
          "video_object_id":    { "type": "text" },
          "video_download_url": { "type": "text" },
          "error":              { "type": "text" },
          "retry_count":        { "type": "integer", "default": "0" },
          "attempts":           { "type": "jsonb", "default": "'[]'::jsonb" },
          "created_at":         { "type": "timestamptz", "default": "now()" },
          "updated_at":         { "type": "timestamptz", "default": "now()" },
          "completed_at":       { "type": "timestamptz" }
        },
        "indexes": {
          "idx_jobs_creative_id": { "columns": ["creative_id"] },
          "idx_jobs_status":      { "columns": ["status"] },
          "idx_jobs_created_at":  { "columns": ["created_at"] }
        }
      }
    }
  },
  "name": "create jobs table for pipeline monitoring",
  "dry_run": false
}
