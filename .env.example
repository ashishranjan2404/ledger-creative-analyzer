# Cumulus / IonRouter
IONROUTER_KEY=ion_xxxxxxxxxxxxxxxxxxxx

# Optional overrides — leave unset to use defaults baked into creative_analyzer.py
# IONROUTER_BASE_URL=https://api.ionrouter.io/v1
# CUMULUS_MODEL=qwen3.5-122b-a10b

# Photon Spectrum — delivery pipeline (ledger-delivery/)
PHOTON_WORKSPACE_ID=
PHOTON_PROJECT_ID=
PHOTON_API_KEY=

# BytePlus Seedance (brief generator + intro video)
# Sissi's brief_generator.py + generate_intro.py read ARK_API_KEY
ARK_API_KEY=your_ark_api_key_here

# Butterbase (jobs DB + video storage)
BUTTERBASE_APP_ID=app_xxxxxxxxxxxxxxxxxxxx
BUTTERBASE_API_URL=https://api.butterbase.ai
BUTTERBASE_API_KEY=bb_sk_xxxxxxxxxxxxxxxxxxxx

# Neo4j Aura (creative feature graph)
NEO4J_URI=neo4j+s://<instance>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<password>
NEO4J_DATABASE=neo4j

# Cartesia TTS (fallback narration when Seedance is unavailable)
CARTESIA_API_KEY=
# Optional override — defaults are fine for most cases
# CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091
# CARTESIA_MODEL_ID=sonic-2

# Alex's GraphRAG chat API (insights source). Leave unset for the default.
# LEDGER_CHAT_URL=http://45.78.200.9:7070/api/chat/stream/v5?content={content}&graphRag=true&neoBrain=false&sreBrain=false
